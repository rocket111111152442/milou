rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Les fichiers du chat sont uploadés via l'API serveur (Admin SDK).
    match /mission-chats/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /listings/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
